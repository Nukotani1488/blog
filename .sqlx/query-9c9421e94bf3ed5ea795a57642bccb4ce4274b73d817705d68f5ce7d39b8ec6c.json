{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            p.id, \n            p.title, \n            u.username AS author, \n            p.created_at, \n            p.summary\n        FROM posts p \n        JOIN users u ON p.author_id = u.id \n        WHERE p.title ILIKE $1 OR p.content ILIKE $1 \n        ORDER BY p.created_at DESC \n        LIMIT $2 OFFSET $3\n        ",
